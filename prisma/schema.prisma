// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ==========================================
// 1. SESIONES Y ARTISTAS
// ==========================================

model Session {
  id              String   @id @default(cuid())
  title           String
  sessionNumber   String
  dateText        String
  gifUrl          String?
  trailerUrl      String?
  spinup          String?  @db.Text
  
  // Columna Izquierda (Info extra en la vista)
  showLeftColInfo Boolean  @default(true)
  leftColLine1    String?
  leftColLine2    String?
  leftColLine3    String?

  // Relación con los artistas (1 Sesión tiene N Artistas)
  artists         Artist[]

  // Relación con fotos de Galería
  photos          Photo[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Artist {
  id           String   @id @default(cuid())
  name         String
  photo        String?  // Usado para la tarjeta del Lineup
  profilePhoto String?  // Usado para la página interna del artista
  bio          String?  @db.Text
  youtube      String?

  // Relación obligatoria con Session
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ==========================================
// 2. CONTENIDO EDITABLE (HOME Y ABOUT)
// ==========================================
// Funcionan como "Singleton", es decir, la base de datos siempre 
// mantendrá 1 solo registro con un ID fijo ("home-singleton" o "about-singleton")

model HomeContent {
  id                   String   @id @default("home-singleton")
  heroTitle            String?
  heroSubtitle         String?
  tickerText           String?  @db.Text
  heroBackground       String?  // GIF o Video (.mp4) de fondo

  featuredSessionId    String?
  featuredSessionTitle String?
  featuredSessionGif   String?
  
  featuredItemImage    String?
  featuredItemTitle    String?
  featuredItemSubtitle String?

  storeEnabled         Boolean  @default(false) // Toggle global para E-commerce

  updatedAt            DateTime @updatedAt
}

model AboutContent {
  id          String   @id @default("about-singleton")
  title       String?
  content     String?  @db.Text
  showMarquee Boolean  @default(true)
  coverImage  String?

  updatedAt   DateTime @updatedAt
}

model Photo {
  id        String   @id @default(cuid())
  url       String
  caption   String?  // Ej: B2B Especial... 
  date      DateTime @default(now()) // Fecha personalizada, sino hereda la de la sesiÃ³n

  // Relación opcional con Session
  sessionId String?
  session   Session?  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ==========================================
// 3. E-COMMERCE / TIENDA 
// ==========================================

model Product {
  id          String   @id @default(cuid())
  title       String
  price       Int
  description String?  @db.Text
  images      String[] // Array de URLs (Para subir a Cloudinary)
  category    String   @default("Ropa") // Ej: Ropa, Accesorios, Merch
  isAvailable Boolean  @default(true)
  stock       Int      @default(0)
  views       Int      @default(0) // Analytics: Producto más visitado

  sizes       String[] @default([]) // Ej: ["S", "M", "L", "XL"]

  orderItems  OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id              String   @id @default(cuid())
  customerName    String
  customerEmail   String
  customerPhone   String?
  shippingAddress String?  @db.Text
  status          String   @default("PENDING") // PENDING, PAID, SHIPPED, DELIVERED, CANCELLED
  totalAmount     Int

  items           OrderItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  size        String?  // Talla seleccionada al momento de la compra
  priceAtTime Int      // Precio histórico congelado al momento del pago

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  createdAt   DateTime @default(now())
}

// ==========================================
// 4. MARKETING / NEWSLETTER
// ==========================================

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ==========================================
// 5. VIP INVITATIONS & EVENTS
// ==========================================

model VipEventContent {
  id              String   @id @default("vip-singleton")
  title           String?
  dateText        String?
  location        String?
  rules           String?  @db.Text
  lineup          String?  @db.Text
  
  // Nuevos campos para layout asimétrico
  welcomeImage    String?
  welcomeText     String?  @db.Text
  infoImage       String?
  farewellText    String?  @db.Text

  updatedAt       DateTime @updatedAt
}

model WinnerEventContent {
  id              String   @id @default("winner-singleton")
  title           String?
  dateText        String?
  location        String?
  rules           String?  @db.Text
  lineup          String?  @db.Text
  
  welcomeImage    String?
  welcomeText     String?  @db.Text
  infoImage       String?
  farewellText    String?  @db.Text

  updatedAt       DateTime @updatedAt
}

model EmailTemplateContent {
  id              String   @id @default("email-singleton")
  subjectGuest    String?  
  titleGuest      String?  
  messageGuest    String?  @db.Text
  
  subjectWinner   String?  
  titleWinner     String?  
  messageWinner   String?  @db.Text
  
  footer          String?  @db.Text
  updatedAt       DateTime @updatedAt
}

model Invitation {
  id          String   @id @default(cuid())
  guestName   String
  guestEmail  String
  token       String   @unique
  type        String   @default("GUEST") // Puede ser "GUEST" o "WINNER"
  isScanned   Boolean  @default(false)
  scannedAt   DateTime?
  eventDate   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
