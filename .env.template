# Database Configuration
DATABASE_URL="postgres://tu_usuario:tu_contraseña@tu_host:5432/tu_base_de_datos"

# Next Auth Configuration
# Genera un NEXTAUTH_SECRET con: `openssl rand -base64 32` en la terminal
NEXTAUTH_SECRET="tu_secreto_generado"
NEXTAUTH_URL="https://tu-dominio-en-vercel.vercel.app" # Reemplaza por tu URL de Vercel (o http://localhost:3000 si estás en local)

# Cloudinary (Para la subida y optimización de imágenes/videos)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="tu_cloud_name_de_cloudinary"
CLOUDINARY_API_KEY="tu_api_key_de_cloudinary"
CLOUDINARY_API_SECRET="tu_api_secret_de_cloudinary"

# (Opcional) Admin credentials iniciales si tienes un script de seed, o
# cualquier otra variable que necesites para inicializar cosas en producción
ADMIN_INITIAL_EMAIL="admin@tallerzero.com"
ADMIN_INITIAL_PASSWORD="tu_password_seguro_para_el_admin"
